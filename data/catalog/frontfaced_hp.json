{
  "meta": {
    "category": "halfpallet",
    "display_label": "Front-Faced Half Pallet",
    "hero_image": "assets/references/halfpallet/frontfaced_hp.png"
  },
  "controls": [
    {
      "id": "footprint",
      "label": "Footprint",
      "type": "single",
      "required": true,
      "options": [
        {
          "key": "fp-24x48",
          "label": "24 × 48",
          "base_value": 0,
          "dims": { "width_in": 24, "depth_in": 48, "height_in": 48 },
          "rules": { "header_allowed": true, "shipper_allowed": true }
        }
      ],
      "notes": "Half pallet footprint is fixed (24×48). Height placeholder; adjust later if needed."
    },
    {
      "id": "display_body",
      "label": "Display Body",
      "type": "single",
      "required": true,
      "options": [
        { "key": "body-standard", "label": "Standard", "base_value": 0 },
        { "key": "body-alt", "label": "Alternate (Placeholder)", "base_value": 0 }
      ],
      "notes": "Body variants can differ; placeholder options until confirmed."
    },
    {
      "id": "header",
      "label": "Header / Sign",
      "type": "single",
      "required": true,
      "options": [
        { "key": "header-yes", "label": "Yes", "base_value": 0 },
        { "key": "header-no", "label": "No", "base_value": 0 }
      ],
      "notes": "If Yes, resolves to the header/sign kit part for this display."
    },
    {
      "id": "shelf_count",
      "label": "Number of Shelves",
      "type": "number",
      "required": true,
      "min": 0,
      "notes": "Linear pricing: shelf unit × count."
    },
    {
      "id": "divider_count",
      "label": "Number of Dividers",
      "type": "number",
      "required": true,
      "min": 0,
      "notes": "Linear pricing: divider unit × count."
    },
    {
      "id": "shipper",
      "label": "Shipper",
      "type": "single",
      "required": true,
      "options": [
        { "key": "shipper-yes", "label": "Yes", "base_value": 0 },
        { "key": "shipper-no", "label": "No", "base_value": 0 }
      ],
      "notes": "Per-unit shipper; if Yes, resolves to a footprint-specific part."
    },
    {
      "id": "assembly",
      "label": "Assembly",
      "type": "single",
      "required": true,
      "options": [
        { "key": "assembly-kdf", "label": "KDF", "base_value": 0 },
        { "key": "assembly-turnkey", "label": "Turnkey", "base_value": 0 }
      ],
      "notes": "KDF/Turnkey are non-priced switches; only Turnkey with touches adds cost."
    },
    {
      "id": "product_touches",
      "label": "Product Touches",
      "type": "number",
      "required": false,
      "min": 0,
      "notes": "Only used when Assembly = Turnkey; cost = touch unit × touches."
    },
    {
      "id": "quantity",
      "label": "Quantity",
      "type": "number",
      "required": true,
      "min": 1,
      "notes": "Used for break pricing (floor) and program total."
    }
  ],
  "parts": {
    "hpff-base-fp-24x48": {
      "label": "Front-Faced Half Pallet Base (24×48)",
      "base_value": 0
    },
    "hpff-body-standard": {
      "label": "Display Body — Standard",
      "base_value": 0
    },
    "hpff-body-alt": {
      "label": "Display Body — Alternate (Placeholder)",
      "base_value": 0
    },
    "hpff-shelf-unit": {
      "label": "Shelf (per shelf)",
      "base_value": 0
    },
    "hpff-divider-unit": {
      "label": "Divider (per divider)",
      "base_value": 0
    },
    "hpff-header": {
      "label": "Header / Sign Kit",
      "base_value": 0
    },
    "header-none": {
      "label": "No Header / Sign",
      "base_value": 0
    },
    "hpff-shipper-fp-24x48": {
      "label": "Shipper (24×48)",
      "base_value": 0
    },
    "assembly-touch-unit": {
      "label": "Assembly Touch (per touch)",
      "base_value": 0.12
    }
  },
  "rules": {
    "resolve_footprint_base": {
      "based_on_control": "footprint",
      "map": {
        "fp-24x48": "hpff-base-fp-24x48"
      }
    },
    "resolve_display_body": {
      "based_on_control": "display_body",
      "map": {
        "body-standard": "hpff-body-standard",
        "body-alt": "hpff-body-alt"
      }
    },
    "resolve_header": {
      "when_control": "header",
      "when_value": "header-yes",
      "based_on_control": "footprint",
      "map": {
        "fp-24x48": "hpff-header"
      },
      "else": "header-none"
    },
    "resolve_shelves": {
      "quantity_control": "shelf_count",
      "map_by": "footprint",
      "map": {
        "fp-24x48": "hpff-shelf-unit"
      },
      "else": null,
      "pricing": "linear"
    },
    "resolve_dividers": {
      "quantity_control": "divider_count",
      "map_by": "footprint",
      "map": {
        "fp-24x48": "hpff-divider-unit"
      },
      "else": null,
      "pricing": "linear"
    },
    "resolve_shipper": {
      "when_control": "shipper",
      "when_value": "shipper-yes",
      "based_on_control": "footprint",
      "map": {
        "fp-24x48": "hpff-shipper-fp-24x48"
      },
      "else": null
    },
    "resolve_assembly_touches": {
      "when_control": "assembly",
      "when_value": "assembly-turnkey",
      "quantity_control": "product_touches",
      "min_quantity": 1,
      "part": "assembly-touch-unit",
      "pricing": "linear",
      "else": null
    }
  },
  "policy": {
    "matrix_markups": [
      [0.35, 0.4, 0.45],
      [0.3, 0.35, 0.4],
      [0.25, 0.3, 0.35]
    ],
    "break_pricing": {
      "selection": "floor",
      "sub_100_smoothing": {
        "enabled": true,
        "method": "exponential",
        "tiers": [1, 25, 50, 75, 100]
        }
    },
    "display_weight_round": 0.01,
    "markup_application": "program_total"
  }
}