  "rules": {
    "resolve_footprint_base": {
      "based_on_control": "footprint",
      "map": {
        "fp-36x12x12": "pdq-fp-36x12x12",
        "fp-36x17x12": "pdq-fp-36x17x12",
        "fp-48x12x12": "pdq-fp-48x12x12",
        "fp-48x17x12": "pdq-fp-48x17x12"
      }
    },
    "resolve_header": {
      "when_control": "header",
      "when_value": "header-yes",
      "based_on_control": "footprint",
      "match_on_dim": "width_in",
      "map": { "36": "header-8in-36", "48": "header-8in-48" },
      "else": "header-none"
    },
    "resolve_dividers": {
      "quantity_control": "divider_count",
      "map_by": "footprint",
      "map": {
        "fp-36x12x12": "divider-fp-36x12x12",
        "fp-36x17x12": "divider-17",
        "fp-48x12x12": "divider-fp-48x12x12",
        "fp-48x17x12": "divider-17"
      },
      "else": null,
      "pricing": "linear"
    },
    "resolve_shipper": {
      "when_control": "shipper",
      "when_value": "shipper-yes",
      "based_on_control": "footprint",
      "map": {
        "fp-36x12x12": "shipper-fp-36x12x12",
        "fp-36x17x12": "shipper-fp-36x17x12",
        "fp-48x12x12": "shipper-fp-48x12x12",
        "fp-48x17x12": "shipper-fp-48x17x12"
      },
      "else": null
    },
    "resolve_assembly_touches": {
      "when_control": "assembly",
      "when_value": "assembly-turnkey",
      "quantity_control": "product_touches",
      "min_quantity": 1,
      "part": "assembly-touch-unit",
      "pricing": "linear",
      "else": null
    }
  },
  "policy": {
    "matrix_markups": [
      [0.35, 0.4, 0.45],
      [0.3, 0.35, 0.4],
      [0.25, 0.3, 0.35]
    ],
    "break_pricing": {
      "selection": "floor",
      "sub_100_smoothing": {
        "enabled": true,
        "method": "exponential",
        "tiers": [1, 25, 50, 75, 100]
      }
    },
    "display_weight_round": 0.01,
    "markup_application": "program_total"
  }
}