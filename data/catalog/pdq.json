{
  "meta": {
    "category": "pdq",
    "display_label": "PDQ Tray",
    "hero_image": "assets/references/pdq/digital_pdq_tray.png"
  },
  "controls": [
    {
      "id": "footprint",
      "label": "Footprint",
      "type": "single",
      "required": true,
      "options": [
        {
          "key": "fp-36x12x12",
          "label": "36 × 12 × 12",
          "base_value": 0,
          "dims": {
            "width_in": 36,
            "depth_in": 12,
            "height_in": 12
          },
          "rules": {
            "header_allowed": true,
            "shipper_allowed": true
          }
        },
        {
          "key": "fp-36x17x12",
          "label": "36 × 17 × 12",
          "base_value": 0,
          "dims": {
            "width_in": 36,
            "depth_in": 17,
            "height_in": 12
          },
          "rules": {
            "header_allowed": true,
            "shipper_allowed": true
          }
        },
        {
          "key": "fp-48x12x12",
          "label": "48 × 12 × 12",
          "base_value": 0,
          "dims": {
            "width_in": 48,
            "depth_in": 12,
            "height_in": 12
          },
          "rules": {
            "header_allowed": true,
            "shipper_allowed": true
          }
        },
        {
          "key": "fp-48x17x12",
          "label": "48 × 17 × 12",
          "base_value": 0,
          "dims": {
            "width_in": 48,
            "depth_in": 17,
            "height_in": 12
          },
          "rules": {
            "header_allowed": true,
            "shipper_allowed": true
          }
        }
      ]
    },
    {
      "id": "quantity",
      "label": "Quantity",
      "type": "number",
      "required": true,
      "min": 1,
      "notes": "Used for break pricing (floor) and program total."
    },
    {
      "id": "assembly",
      "label": "Assembly",
      "type": "single",
      "required": true,
      "options": [
        {
          "key": "assembly-kdf",
          "label": "KDF",
          "base_value": 0
        },
        {
          "key": "assembly-turnkey",
          "label": "Turnkey",
          "base_value": 0
        }
      ],
      "notes": "KDF adds no fulfillment/assembly cost. Turnkey adds tray assembly/pack-out and optional header pack-out, plus divider assembly and product fill when applicable."
    },
    {
      "id": "product_touches",
      "label": "Product Touches",
      "type": "number",
      "required": false,
      "min": 0,
      "notes": "Only used when Assembly = Turnkey. Product fill cost is tiered by program quantity and increases with the number of touches (base + adders; adders cap at 20)."
    },
    {
      "id": "header",
      "label": "Header",
      "type": "single",
      "required": true,
      "options": [
        {
          "key": "header-yes",
          "label": "Yes",
          "base_value": 0
        },
        {
          "key": "header-no",
          "label": "No",
          "base_value": 0
        }
      ],
      "notes": "If Yes is chosen, the priced header part depends on footprint width: 36\" → header-8in-36, 48\" → header-8in-48. If Assembly = Turnkey, header pack-out is also applied."
    },
    {
      "id": "divider_count",
      "label": "Number of Dividers",
      "type": "number",
      "required": true,
      "min": 0,
      "notes": "Linear piece pricing: unit divider price × count. If Assembly = Turnkey, divider assembly is also applied (base + adders; adders cap at 8)."
    },
    {
      "id": "shipper",
      "label": "Shipper",
      "type": "single",
      "required": true,
      "options": [
        {
          "key": "shipper-yes",
          "label": "Yes",
          "base_value": 0
        },
        {
          "key": "shipper-no",
          "label": "No",
          "base_value": 0
        }
      ],
      "notes": "Per-unit shipper; if Yes, resolves to a footprint-specific part."
    },
    {
      "id": "unit_weight_unit",
      "label": "Product Weight",
      "type": "single",
      "required": true,
      "options": [
        {
          "key": "lb",
          "label": "Pounds (lb)",
          "base_value": 0
        },
        {
          "key": "oz",
          "label": "Ounces (oz)",
          "base_value": 0
        }
      ],
      "notes": "If oz is selected, unit weight is converted to pounds for total lbs."
    },
    {
      "id": "unit_weight_value",
      "label": "Unit Weight — Value",
      "type": "number",
      "required": true,
      "min": 0,
      "notes": "Numeric value of unit weight; paired with the selected unit (oz/lb)."
    },
    {
      "id": "complexity_level",
      "label": "Complexity",
      "type": "single",
      "required": true,
      "options": [
        {
          "key": "cx-low",
          "label": "Low",
          "base_value": 0
        },
        {
          "key": "cx-med",
          "label": "Medium",
          "base_value": 0
        },
        {
          "key": "cx-high",
          "label": "High",
          "base_value": 0
        }
      ],
      "notes": "Adds 0% / 5% / 10% to the base 35% markup respectively."
    }
  ],
